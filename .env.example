# Turso (libSQL) — required on Vercel for persistent multiplayer state.
# For local dev you can omit both; the app uses file:./local.db automatically.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional: LAN hostname only (no scheme/port) when opening the dev server from another device, e.g. http://172.20.10.6:3000 — unblocks Next.js dev `/_next` requests for that host.
# DEV_LAN_HOST=172.20.10.6
